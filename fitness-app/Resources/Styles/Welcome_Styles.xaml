<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:pinview="clr-namespace:PINView.Maui;assembly=PINView.Maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    
    <!-- Background gradient -->
    
    <LinearGradientBrush x:Key="Page01BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource OliveGreen}" Offset="0"/>
        <GradientStop Color="{StaticResource White}" Offset="0.35"/>
        <GradientStop Color="{StaticResource White}" Offset="0.65"/>
        <GradientStop Color="{StaticResource OliveGreen}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="Page02BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource GoldenYellow}" Offset="-0.13"/>
        <GradientStop Color="{StaticResource White}" Offset="0.35"/>
        <GradientStop Color="{StaticResource White}" Offset="0.65"/>
        <GradientStop Color="{StaticResource CoralRed}" Offset="1.13"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="Page03BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource GoldenYellow}" Offset="-0.13"/>
            <GradientStop Color="{StaticResource White}" Offset="0.35"/>
            <GradientStop Color="{StaticResource White}" Offset="0.65"/>
            <GradientStop Color="{StaticResource GoldenYellow}" Offset="1.13"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="Page04BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource CoralRed}" Offset="-0.13"/>
        <GradientStop Color="{StaticResource White}" Offset="0.35"/>
        <GradientStop Color="{StaticResource White}" Offset="0.65"/>
        <GradientStop Color="{StaticResource CoralRed}" Offset="1.13"/>
    </LinearGradientBrush>
    
    
    <!-- Border (Ellipse Shape) -->
    
    <Style x:Key="CircleBorderStyle" TargetType="Border">
        <Setter Property="StrokeThickness" Value="3"/>
        <Setter Property="StrokeShape" Value="Ellipse"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="WidthRequest" Value="460"/>
        <Setter Property="HeightRequest" Value="420"/>
        <Setter Property="Margin" Value="0,0,0,40"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>
    
    <!-- Border (Square Shape) -->
    
    <Style x:Key="SquareBorderStyle" TargetType="Border">
        <Setter Property="StrokeThickness" Value="3"/>
        <Setter Property="StrokeShape" Value="Rectangle"/>
        <Setter Property="BackgroundColor" Value="Black"/>
        <Setter Property="WidthRequest" Value="460"/>
        <Setter Property="HeightRequest" Value="460"/>
        <Setter Property="Margin" Value="0,0,0,40"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>
    
    <!-- AbsoluteLayout for Images -->
    <Style x:Key="ImageContainerStyle" TargetType="AbsoluteLayout">
        <Setter Property="WidthRequest" Value="352"/>
        <Setter Property="HeightRequest" Value="420"/>
        <Setter Property="Margin" Value="0,120,0,0"/>
    </Style>
    
    <!-- Ellipse Images -->
    <Style x:Key="EllipseImage206Style" TargetType="Image">
        <Setter Property="WidthRequest" Value="310"/>
        <Setter Property="AbsoluteLayout.LayoutBounds" Value="0.5,0.5,1,1"/>
        <Setter Property="AbsoluteLayout.LayoutFlags" Value="All"/>
    </Style>
    
    <Style x:Key="EllipseImage205Style" TargetType="Image">
        <Setter Property="WidthRequest" Value="280"/>
        <Setter Property="Margin" Value="0,32,0,0"/>
        <Setter Property="AbsoluteLayout.LayoutBounds" Value="0.5,0.5,1,1"/>
        <Setter Property="AbsoluteLayout.LayoutFlags" Value="All"/>
    </Style>
    
    <Style x:Key="FigureImage5045Style" TargetType="Image">
        <Setter Property="WidthRequest" Value="280"/>
        <Setter Property="Margin" Value="0,32,0,0"/>
        <Setter Property="AbsoluteLayout.LayoutBounds" Value="0.5,0.5,1,1"/>
        <Setter Property="AbsoluteLayout.LayoutFlags" Value="All"/>
    </Style>
    
    <Style x:Key="WomanWithDumbbellsImageStyle" TargetType="Image">
        <Setter Property="WidthRequest" Value="352"/>
        <Setter Property="AbsoluteLayout.LayoutBounds" Value="0.5,0.5,1,1"/>
        <Setter Property="AbsoluteLayout.LayoutFlags" Value="All"/>
    </Style>
    
    <Style x:Key="WomanDrinkingImageStyle" TargetType="Image">
        <Setter Property="Source" Value="{FileImageSource woman_drinking}"/>
        <Setter Property="WidthRequest" Value="352"/>
        <Setter Property="AbsoluteLayout.LayoutBounds" Value="0.5,0.5,1,1"/>
        <Setter Property="AbsoluteLayout.LayoutFlags" Value="All"/>
    </Style>
    
    <Style x:Key="BuggyWoman" TargetType="Image">
        <Setter Property="WidthRequest" Value="352"/>
        <Setter Property="AbsoluteLayout.LayoutBounds" Value="0.5,0.5,1,1"/>
        <Setter Property="AbsoluteLayout.LayoutFlags" Value="All"/>
    </Style>
    
    <!-- Title Label (Large) -->
    <Style x:Key="LargeTitleLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="40"/>
        <Setter Property="FontFamily" Value="BebasRegular"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
    </Style>
    
    <!-- Navigation Label (Skip/Next) -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontFamily" Value="MontserratMedium"/>
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="BackgroundColor" Value="Transparent"></Setter>
        <Setter Property="Padding" Value="0"></Setter>
        <Setter Property="Margin" Value="0"></Setter>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>
    
    <Style x:Key="ActiveIndicatorStyle" TargetType="BoxView">
        <Setter Property="WidthRequest" Value="12"/>
        <Setter Property="HeightRequest" Value="5"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="BackgroundColor" Value="{StaticResource OliveGreen}"/>
    </Style>

    <Style x:Key="InactiveIndicatorStyle" TargetType="BoxView">
        <Setter Property="WidthRequest" Value="5"/>
        <Setter Property="HeightRequest" Value="5"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="BackgroundColor" Value="Black"/>
    </Style>
    
    <Style x:Key="MainPageBorderStyle" TargetType="Border">
        <Setter Property="StrokeShape" Value="Rectangle"/>
        <Setter Property="StrokeThickness" Value="0"></Setter>
        <Setter Property="WidthRequest" Value="300"/>
        <Setter Property="HeightRequest" Value="400"/>
        <Setter Property="Margin" Value="0,0,0,44"/>
    </Style>
    
    <Style x:Key="Ellipse201ImageStyle" TargetType="Image">
        <Setter Property="WidthRequest" Value="168"/>
        <Setter Property="VerticalOptions" Value="End"/>
        <Setter Property="HorizontalOptions" Value="End"/>
    </Style>
    
    <Style x:Key="Vector2ImageStyle" TargetType="Image">
        <Setter Property="WidthRequest" Value="156"/>
        <Setter Property="VerticalOptions" Value="End"/>
        <Setter Property="HorizontalOptions" Value="Start"/>
    </Style>
    
    <Style x:Key="Vector3ImageStyle" TargetType="Image">
        <Setter Property="WidthRequest" Value="172"/>
        <Setter Property="HeightRequest" Value="156"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="Margin" Value="60,0,0,20"/>
    </Style>
    
    <Style x:Key="GirlDoingBicepsImageStyle" TargetType="Image">
        <Setter Property="WidthRequest" Value="576"/>
        <Setter Property="HeightRequest" Value="372"/>
        <Setter Property="VerticalOptions" Value="End"/>
    </Style>
    
    <Style x:Key="SubtitleLabelStyle" TargetType="Label">
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontFamily" Value="DMSans_18ptRegular"/>
        <Setter Property="LineBreakMode" Value="WordWrap"/>
        <Setter Property="Margin" Value="28"/>
        <Setter Property="TextColor" Value="Black"/>
    </Style>
    
    <Style x:Key="MainButtonStyle" TargetType="Button">
        <Setter Property="WidthRequest" Value="180"/>
        <Setter Property="HeightRequest" Value="56"/>
        <Setter Property="Margin" Value="0,0,0,80"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="BackgroundColor" Value="Black"/>
        <Setter Property="VerticalOptions" Value="Start"/>
        <Setter Property="FontFamily" Value="BebasRegular"/>
        <Setter Property="FontSize" Value="20"/>
    </Style>
    
    <Style x:Key="IndicatorFrameStyle"
           TargetType="Frame">
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor"
                                    Value="{StaticResource PrimaryBlack}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Selected">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor"
                                    Value="{StaticResource OliveGreen}" />
                            <Setter Property="WidthRequest"
                                    Value="14" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
        <Setter Property="HeightRequest" Value="8"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="HasShadow" Value="False"/>
        <Setter Property="WidthRequest" Value="8"/>
    </Style>
    
    <Style x:Key="IndicatorViewStyle" TargetType="IndicatorView">
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>
    
    <!-- Login/Registration -->
    
    <Style x:Key="MainContainerStyle" TargetType="Grid">
        <Setter Property="Margin" Value="12,20,12,20"/>
    </Style>
    
    <Style x:Key="TitleContainerStyle" TargetType="StackLayout">
        <Setter Property="Spacing" Value="16"/>
        <Setter Property="Margin" Value="12,0,0,40"/>
    </Style>
    
    <Style x:Key="TitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontFamily" Value="BebasRegular"/>
        <Setter Property="TextColor" Value="Black"/>
    </Style>
    
    <Style x:Key="TitleDescriptionStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontFamily" Value="DMSansMedium"/>
        <Setter Property="TextColor" Value="{StaticResource SlateGray}"/>
    </Style>
    
    <Style x:Key="BodyContainerStyle" TargetType="StackLayout">
        <Setter Property="Spacing" Value="8"/>
        <Setter Property="Margin" Value="12,0,12,40"/>
    </Style>
    
    <Style x:Key="EntryLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontFamily" Value="MontserratMedium"/>
        <Setter Property="TextColor" Value="{StaticResource SlateGray}"/>
    </Style>
    
    <Style x:Key="EntryStyle" TargetType="Entry">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="DMSansRegular"/>
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="HeightRequest" Value="54"/>
        <Setter Property="BackgroundColor" Value="{StaticResource WhisperGray}"/>
    </Style>
    
    <Style x:Key="EntryImageStyle" TargetType="Image">
        <Setter Property="HorizontalOptions" Value="End"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>
    
    <Style x:Key="BodyOptionContainerStyle" TargetType="StackLayout">
       <Setter Property="Orientation" Value="Horizontal"/>
       <Setter Property="HorizontalOptions" Value="End"/>
       <Setter Property="Margin" Value="0,4,16,0"></Setter>
    </Style>
    
    <Style x:Key="BodyOptionButtonStyle" TargetType="Label">
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="MontserratSemiBold"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    
    <Style x:Key="MainGreenButtonStyle" TargetType="Button">
        <Setter Property="WidthRequest" Value="318"/>
        <Setter Property="HeightRequest" Value="56"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontFamily" Value="BebasRegular"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="BackgroundColor" Value="{StaticResource OliveGreen}"/>
    </Style>
    
    <Style x:Key="OptionLabelStyle" TargetType="Label">
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="Margin" Value="0,16,0,12"/>
        <Setter Property="FontFamily" Value="MontserratMedium"></Setter>
        <Setter Property="FontSize" Value="12"></Setter>
        <Setter Property="TextColor" Value="{StaticResource SlateGray}"></Setter>
    </Style>
    
    <Style x:Key="GoogleButtonStyle" TargetType="Button">
        <Setter Property="WidthRequest" Value="318"/>
        <Setter Property="HeightRequest" Value="56"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="TextColor" Value="{StaticResource ShadowGray}"/>
        <Setter Property="FontFamily" Value="MontserratSemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BackgroundColor" Value="{StaticResource WhisperGray}"/>
        <Setter Property="BorderColor" Value="{StaticResource CloudGray}"/>
        <Setter Property="BorderWidth" Value="0.8"/>
        <Setter Property="Padding" Value="0,0,70,0"/>
        <Setter Property="ContentLayout" Value="Left,50"/>
    </Style>
    
    <Style x:Key="FacebookButtonStyle" TargetType="Button">
        <Setter Property="WidthRequest" Value="318"/>
        <Setter Property="HeightRequest" Value="56"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="FontFamily" Value="MontserratSemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BackgroundColor" Value="{StaticResource BoldAzure}"/>
        <Setter Property="BorderColor" Value="{StaticResource DimGray}"/>
        <Setter Property="BorderWidth" Value="0.25"/>
        <Setter Property="Padding" Value="0,0,60,0"/>
        <Setter Property="ContentLayout" Value="Left,40"/>
    </Style>
    
    <Style x:Key="BottomContainerStyle" TargetType="StackLayout">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="Margin" Value="0,40,0,0"></Setter>
    </Style>
    
    <Style x:Key="BottomLabelStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource DarkGrey}"/>
        <Setter Property="FontFamily" Value="MontserratMedium"/>
        <Setter Property="VerticalOptions" Value="End"/>
    </Style>
    <Style x:Key="BottomButtonBold" TargetType="Button">
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="BackgroundColor" Value="Transparent"></Setter>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="VerticalOptions" Value="End"></Setter>
        <Setter Property="FontFamily" Value="MontserratBold"/>
        <Setter Property="Padding" Value="0"></Setter>
    </Style>
    
    <Style x:Key="ResendButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="MontserratSemiBold" />
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Padding" Value="0" />
        <Setter Property="WidthRequest" Value="68" />
        <Setter Property="TextColor" Value="Black" />
    </Style>
    <Style x:Key="PinViewStyle" TargetType="pinview:PINView">
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="BoxShape" Value="RoundCorner" />
        <Setter Property="PINInputType" Value="Numeric" />
        <Setter Property="BoxSize" Value="60" />
        <Setter Property="BoxSpacing" Value="2" />
        <Setter Property="BoxFocusAnimation" Value="ZoomInOut" />
        <Setter Property="PINLength" Value="6" />
        <Setter Property="BoxBackgroundColor" Value="{StaticResource WhisperGray}" />
        <Setter Property="BoxFocusColor" Value="{StaticResource WhisperGray}" />
    </Style>
    
    <Style x:Key="NavigationPageStyle" TargetType="ContentPage">
        <Setter Property="NavigationPage.IconColor" Value="Black" />
        <Setter Property="NavigationPage.BackButtonTitle" Value="" />
    </Style>
</ResourceDictionary>